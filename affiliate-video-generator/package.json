{
  "name": "affiliate-video-generator",
  "productName": "Affiliate Video Generator",
  "version": "1.0.0",
  "description": "Aplikasi desktop untuk membuat video afiliasi produk kaos secara otomatis.",
  "author": {
    "name": "toolkd",
    "email": "noreply@toolkd.local"
  },
  "main": "src/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "start": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm:dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "start:built": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder --win --x64",
    "build:dir": "npm run build:renderer && electron-builder --win --x64 --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
